# Mr Mainspring local backend environment

NODE_ENV=development
SIGIL_DATA_DIR=./.sigil
SIGIL_MCP_NAME=mr-mainspring
SIGIL_MCP_VERSION=0.1.0

# Persistence backend. Defaults to local JSON files.
# Set to "supabase" only after running backend/supabase/schema.sql.
SIGIL_STORAGE_BACKEND=file
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_DB_SCHEMA=public
SUPABASE_TABLE_PREFIX=sigil_

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
GRIMOIRE_MASTER_KEY=

# Casper testnet / anchor config
CASPER_NETWORK_NAME=casper-test
CASPER_CAIP2_CHAIN_ID=casper:casper-test
CASPER_RPC_URL=
CASPER_ACCOUNT_KEY_PATH=./keys/backend.pem
CASPER_ACCOUNT_KEY_ALGO=ed25519
MEMORY_ANCHOR_CONTRACT_HASH=
MEMORY_ANCHOR_PACKAGE_HASH=

# Casper x402 sidecar/demo resource config
# payment.fetch request_challenge=true performs the first HTTP 402 challenge request only.
# Signed x402 payloads and Casper settlement remain disabled until a facilitator is verified.
X402_FACILITATOR_URL=http://localhost:4022
X402_RESOURCE_DEMO_URL=http://localhost:4021/weather
X402_ASSET_PACKAGE=
X402_ASSET_NAME=

LOG_LEVEL=info
